{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/operations/review.update.input.v0.1.0.json",
  "title": "review.update input",
  "type": "object",
  "additionalProperties": false,
  "required": ["operation", "mode", "review_id", "update"],
  "properties": {
    "operation": {
      "type": "string",
      "enum": ["review.update"]
    },
    "mode": {
      "type": "string",
      "enum": ["plan", "apply"]
    },
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["comment", "decision", "approval", "blocker", "note"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "apply_gate": {
          "type": "string",
          "enum": ["none", "pending", "approved", "blocked"]
        }
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
