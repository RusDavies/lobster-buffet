{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/operations/git.workflow.inspect.output.v0.1.0.json",
  "title": "git.workflow.inspect output",
  "type": "object",
  "additionalProperties": false,
  "required": ["repo", "worktree", "warnings"],
  "properties": {
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_git_repo", "branch", "dirty", "ahead", "behind"],
      "properties": {
        "is_git_repo": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "ahead": {
          "type": "integer",
          "minimum": 0
        },
        "behind": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed_count", "untracked_count"],
      "properties": {
        "changed_count": {
          "type": "integer",
          "minimum": 0
        },
        "untracked_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
