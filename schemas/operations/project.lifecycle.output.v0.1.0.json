{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/operations/project.lifecycle.output.v0.1.0.json",
  "title": "project lifecycle output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation",
    "mode",
    "status",
    "mutates",
    "project",
    "approval",
    "side_effects",
    "adapter_capabilities",
    "preview",
    "verification",
    "warnings",
    "reason"
  ],
  "properties": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "stability"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["project.bootstrap", "project.adopt", "project.repair", "project.migrate", "project.archive"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "stability": {
          "type": "string",
          "enum": ["draft", "experimental", "stable", "deprecated"]
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": ["plan"]
    },
    "status": {
      "type": "string",
      "enum": ["requires_approval"]
    },
    "mutates": {
      "type": "boolean"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ref_policy"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ref_policy": {
          "type": "string",
          "enum": ["opaque_ref"]
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "classes", "reason"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["repo_mutation"]
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "side_effects": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["filesystem.read", "filesystem.write", "git.read", "git.write"]
      }
    },
    "adapter_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preview": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path_policy", "summary"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path_policy": {
            "type": "string",
            "enum": ["category_only"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "description"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
