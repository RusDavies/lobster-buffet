{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/operations/incident.close.input.v0.1.0.json",
  "title": "incident.close input",
  "type": "object",
  "additionalProperties": false,
  "required": ["operation", "mode", "incident_id", "resolution"],
  "properties": {
    "operation": {
      "type": "string",
      "enum": ["incident.close"]
    },
    "mode": {
      "type": "string",
      "enum": ["plan", "apply"]
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "summary"],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["resolved", "superseded", "invalid", "duplicate"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "follow_up_required": {
          "type": "boolean"
        }
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
