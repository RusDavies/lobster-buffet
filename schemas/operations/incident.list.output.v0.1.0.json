{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/operations/incident.list.output.v0.1.0.json",
  "title": "incident.list output",
  "type": "object",
  "additionalProperties": false,
  "required": ["counts", "incidents"],
  "properties": {
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active", "stale", "closed"],
      "properties": {
        "active": {
          "type": "integer",
          "minimum": 0
        },
        "stale": {
          "type": "integer",
          "minimum": 0
        },
        "closed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "incidents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "severity", "title", "updated_at", "resurface"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "stale", "closed"]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "updated_at": {
            "type": "string",
            "minLength": 1
          },
          "resurface": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
