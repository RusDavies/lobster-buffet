{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/local-adapter-fixture.v0.1.0.json",
  "title": "Lobster Buffet local adapter fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "fixture_id", "adapter_api", "capabilities"],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["lobster-buffet.local-adapter-fixture.v0.1.0"]
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "adapter_api": {
      "type": "string",
      "enum": ["lobster-buffet.local-adapter.v0"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "envelope"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "envelope": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ok", "capability", "result", "warnings", "private_data"],
            "properties": {
              "ok": {
                "type": "boolean"
              },
              "capability": {
                "type": "string",
                "minLength": 1
              },
              "result": {
                "type": "object"
              },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "private_data": {
                "type": "object",
                "additionalProperties": false,
                "required": ["contains_private_values", "private_refs_only", "disclosure_policy"],
                "properties": {
                  "contains_private_values": {
                    "type": "boolean"
                  },
                  "private_refs_only": {
                    "type": "boolean"
                  },
                  "disclosure_policy": {
                    "type": "string",
                    "enum": ["category_only", "opaque_ref", "redacted_summary", "local_only", "explicit_disclosure_required"]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
