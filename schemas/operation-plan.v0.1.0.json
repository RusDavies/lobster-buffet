{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.lobster-buffet.local/operation-plan.v0.1.0.json",
  "title": "Lobster Buffet operation plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "plan_id",
    "operation",
    "requested_by",
    "input_summary",
    "side_effects",
    "approval",
    "adapter_capabilities",
    "affected_surfaces",
    "verification",
    "privacy",
    "summary"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["lobster-buffet.operation-plan.v0.1.0"]
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "name", "version", "stability"],
      "properties": {
        "namespace": {
          "type": "string",
          "enum": ["lobster-buffet"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "stability": {
          "type": "string",
          "enum": ["draft", "experimental", "stable", "deprecated"]
        }
      }
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_ref", "surface"],
      "properties": {
        "actor_ref": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "enum": ["discord", "tui", "api", "cron", "unknown"]
        }
      }
    },
    "input_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redaction", "fields"],
      "properties": {
        "redaction": {
          "type": "string",
          "enum": ["private_refs", "redacted", "none"]
        },
        "fields": {
          "type": "object"
        }
      }
    },
    "side_effects": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "none",
          "filesystem.read",
          "filesystem.write",
          "git.read",
          "git.write",
          "network.read",
          "network.write",
          "message.visible_send",
          "external.action",
          "secret.read"
        ]
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "classes", "reason"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "external_action",
              "public_release",
              "destructive_change",
              "secret_access",
              "private_data_export",
              "repo_mutation",
              "visible_message_send"
            ]
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adapter_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "affected_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "ref_policy"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "ref_policy": {
            "type": "string",
            "enum": ["category_only", "opaque_ref", "redacted_summary"]
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "description"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_private_values", "private_refs_only", "disclosure_policy"],
      "properties": {
        "contains_private_values": {
          "type": "boolean"
        },
        "private_refs_only": {
          "type": "boolean"
        },
        "disclosure_policy": {
          "type": "string",
          "enum": ["local_adapter_controlled"]
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
